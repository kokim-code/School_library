@page "/loans"
@inject LoanService LoanService
@inject BookCopyService CopyService
@inject ReaderService ReaderService

<h1>Выдача и возврат</h1>
<p>Раздел фиксирует выдачу книг читателям и закрывает операции при возврате.</p>

@if (!string.IsNullOrWhiteSpace(message)) { <div class="message">@message</div> }

<div class="panel grid-form">
    <select @bind="copyId">
        @foreach (var copy in availableCopies) { <option value="@copy.Id">@copy.InventoryNumber - @copy.Book?.Title</option> }
    </select>
    <select @bind="readerId">
        @foreach (var reader in readers) { <option value="@reader.Id">@reader.FullName</option> }
    </select>
    <input type="date" @bind="dueDate" />
    <button @onclick="Issue">Выдать книгу</button>
</div>

<table>
    <thead><tr><th>Книга</th><th>Экземпляр</th><th>Читатель</th><th>Дата выдачи</th><th>Срок</th><th>Возврат</th><th></th></tr></thead>
    <tbody>
    @foreach (var loan in loans)
    {
        <tr>
            <td>@loan.BookCopy?.Book?.Title</td>
            <td>@loan.BookCopy?.InventoryNumber</td>
            <td>@loan.Reader?.FullName</td>
            <td>@loan.IssueDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
            <td>@loan.DueDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
            <td>@(loan.ReturnDate?.ToLocalTime().ToString("dd.MM.yyyy") ?? "не возвращена")</td>
            <td>@if (!loan.ReturnDate.HasValue) { <button @onclick="() => Return(loan.Id)">Вернуть</button> }</td>
        </tr>
    }
    </tbody>
</table>

@code {
    private List<Loan> loans = [];
    private List<BookCopy> availableCopies = [];
    private List<Reader> readers = [];
    private int copyId;
    private int readerId;
    private DateTime dueDate = DateTime.Today.AddDays(14);
    private string? message;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loans = await LoanService.GetAllAsync();
        availableCopies = await CopyService.GetAvailableAsync();
        readers = await ReaderService.GetAllAsync();
        copyId = availableCopies.FirstOrDefault()?.Id ?? 0;
        readerId = readers.FirstOrDefault()?.Id ?? 0;
    }

    private async Task Issue()
    {
        try
        {
            if (copyId == 0 || readerId == 0) throw new InvalidOperationException("Выберите экземпляр и читателя");
            await LoanService.IssueAsync(copyId, readerId, dueDate);
            message = "Книга выдана";
            await Load();
        }
        catch (Exception ex) { message = ex.Message; }
    }

    private async Task Return(int id)
    {
        try
        {
            await LoanService.ReturnAsync(id);
            message = "Книга возвращена";
            await Load();
        }
        catch (Exception ex) { message = ex.Message; }
    }
}
